# SOLPI Docker Compose Environment

# ─── Hermes Agent ────────────────────────────────────
HERMES_ENV=development
HERMES_LOG_LEVEL=info
HERMES_UI_PORT=8001
HERMES_GATEWAY_PORT=8002
HERMES_INTERNAL_PORT=8003

# ─── OpenClaude ──────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_LOG_LEVEL=info
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─── OpenClaw ────────────────────────────────────────
OPENCLAW_ENV=development
OPENCLAW_LOG_LEVEL=info
OPENCLAW_BIND=0.0.0.0
OPENCLAW_PORT=18789
# Optional extensions: diagnostics-otel, matrix, qa-lab
OPENCLAW_EXTENSIONS=""
OPENCLAW_INSTALL_BROWSER=
OPENCLAW_INSTALL_DOCKER_CLI=

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Nginx ───────────────────────────────────────────
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_SSL_CERT_PATH=./certs/localhost.crt
NGINX_SSL_KEY_PATH=./certs/localhost.key

# ─── Docker Compose ──────────────────────────────────
COMPOSE_PROJECT_NAME=solpi
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
